@using global::DocumentManagement.Features.Data.Models
@inject global::DocumentManagement.Features.Services.Interfaces.IDocumentTypeService DocumentTypeService

<div class="modal fade show" style="display: block; background-color: rgba(0,0,0,0.5);" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    @(DocumentType?.Id > 0 ? "Edit Document Type" : "Create Document Type")
                </h5>
                <button type="button" class="btn-close" @onclick="OnCancel"></button>
            </div>
            <div class="modal-body">
                <EditForm Model="@DocumentType" OnValidSubmit="OnValidSubmit">
                    <DataAnnotationsValidator />
                    <div class="mb-3">
                        <label class="form-label">Name</label>
                        <InputText class="form-control" @bind-Value="DocumentType.Name" />
                        <ValidationMessage For="@(() => DocumentType.Name)" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">File Extension</label>
                        <InputText class="form-control" @bind-Value="DocumentType.FileExtension" placeholder=".pdf, .docx, .txt" />
                        <ValidationMessage For="@(() => DocumentType.FileExtension)" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <InputTextArea class="form-control" @bind-Value="DocumentType.Description" rows="3" />
                    </div>
                    <div class="mb-3">
                        <div class="form-check">
                            <InputCheckbox class="form-check-input" @bind-Value="DocumentType.IsActive" />
                            <label class="form-check-label">Active</label>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="OnCancel">Cancel</button>
                        <button type="submit" class="btn btn-primary" disabled="@IsSaving">
                            @(IsSaving ? "Saving..." : "Save")
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public DocumentType? DocumentType { get; set; } = new DocumentType();

    [Parameter]
    public EventCallback<DocumentType> OnDocumentTypeSaved { get; set; }

    [Parameter]
    public EventCallback OnCancel { get; set; }

    private bool IsSaving = false;

    private async Task OnValidSubmit()
    {
        IsSaving = true;
        try
        {
            if (DocumentType?.Id > 0)
            {
                await DocumentTypeService.UpdateDocumentTypeAsync(DocumentType);
            }
            else
            {
                await DocumentTypeService.CreateDocumentTypeAsync(DocumentType);
            }

            await OnDocumentTypeSaved.InvokeAsync(DocumentType);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error saving document type: {ex.Message}");
        }
        finally
        {
            IsSaving = false;
        }
    }
}
