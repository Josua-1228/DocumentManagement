@using global::DocumentManagement.Features.Data.Models
@inject global::DocumentManagement.Features.Services.Interfaces.IDocumentService DocumentService
@inject global::DocumentManagement.Features.Services.Interfaces.IDocumentTypeService DocumentTypeService
@inject global::DocumentManagement.Features.Services.Interfaces.IUserService UserService

<div class="modal fade show" style="display: block; background-color: rgba(0,0,0,0.5);" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    @(Document?.Id > 0 ? "Edit Document" : "Upload Document")
                </h5>
                <button type="button" class="btn-close" @onclick="OnCancel"></button>
            </div>
            <div class="modal-body">
                <EditForm Model="@Document" OnValidSubmit="OnValidSubmit">
                    <DataAnnotationsValidator />
                    <div class="mb-3">
                        <label class="form-label">Title</label>
                        <InputText class="form-control" @bind-Value="Document.Title" />
                        <ValidationMessage For="@(() => Document.Title)" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <InputTextArea class="form-control" @bind-Value="Document.Description" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Document Type</label>
                        <InputSelect class="form-select" @bind-Value="Document.DocumentTypeId">
                            <option value="">Select a document type...</option>
                            @foreach (var docType in documentTypes)
                            {
                                <option value="@docType.Id">@docType.Name</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="@(() => Document.DocumentTypeId)" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Owner</label>
                        <InputSelect class="form-select" @bind-Value="Document.UserId">
                            <option value="">Select a user...</option>
                            @foreach (var user in users)
                            {
                                <option value="@user.Id">@user.FullName (@user.Email)</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="@(() => Document.UserId)" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">File Upload</label>
                        <InputFile class="form-control" OnChange="OnFileSelected" />
                        @if (!string.IsNullOrEmpty(selectedFileName))
                        {
                            <small class="text-muted">Selected: @selectedFileName</small>
                        }
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="OnCancel">Cancel</button>
                        <button type="submit" class="btn btn-primary" disabled="@IsSaving">
                            @(IsSaving ? "Saving..." : "Save")
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public Document? Document { get; set; } = new Document();

    [Parameter]
    public EventCallback<Document> OnDocumentSaved { get; set; }

    [Parameter]
    public EventCallback OnCancel { get; set; }

    private List<DocumentType> documentTypes = new();
    private List<User> users = new();
    private bool IsSaving = false;
    private string selectedFileName = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadDocumentTypes();
        await LoadUsers();
    }

    private async Task LoadDocumentTypes()
    {
        try
        {
            documentTypes = (await DocumentTypeService.GetAllDocumentTypesAsync()).ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading document types: {ex.Message}");
        }
    }

    private async Task LoadUsers()
    {
        try
        {
            users = (await UserService.GetAllUsersAsync()).ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading users: {ex.Message}");
        }
    }

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            selectedFileName = file.Name;
            // You would typically handle the file upload here
            // For now, just store the filename
            Document.FileName = file.Name;
        }
    }

    private async Task OnValidSubmit()
    {
        IsSaving = true;
        try
        {
            if (Document?.Id > 0)
            {
                await DocumentService.UpdateDocumentAsync(Document);
            }
            else
            {
                await DocumentService.CreateDocumentAsync(Document);
            }

            await OnDocumentSaved.InvokeAsync(Document);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error saving document: {ex.Message}");
        }
        finally
        {
            IsSaving = false;
        }
    }
}
