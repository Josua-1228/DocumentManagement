@page "/documents"
@using global::DocumentManagement.Features.Data.Models
@inject global::DocumentManagement.Features.Services.Interfaces.IDocumentService DocumentService
@inject global::DocumentManagement.Features.Services.Interfaces.IUserService UserService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<AuthenticatedRoute>
    <PageTitle>Document Management</PageTitle>

    <div class="container mt-5">
        <div class="row mb-4">
            <div class="col">
                <h1>Document Management System</h1>
            </div>
            <div class="col text-end">
                <button class="btn btn-primary" @onclick="CreateDocument">
                    <span class="oi oi-plus"></span> Upload Document
                </button>
            </div>
        </div>
        <div class="col text-end">
            <button class="btn btn-primary" @onclick="CreateDocument">
                <span class="oi oi-plus"></span> Upload Document
            </button>
        </div>
    </div>

    @if (documents == null)
    {
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    }
    else if (documents.Count == 0)
    {
        <div class="alert alert-info" role="alert">
            No documents found. <a href="#" @onclick="() => ShowCreateModal = true">Upload one now</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Title</th>
                        <th>Type</th>
                        <th>Uploaded By</th>
                        <th>Upload Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var doc in documents)
                    {
                        <tr>
                            <td><strong>@doc.Title</strong></td>
                            <td>@doc.DocumentType?.Name</td>
                            <td>@doc.User?.FullName</td>
                            <td>@doc.UploadedAt.ToString("g")</td>
                            <td>
                                <button class="btn btn-sm btn-info" @onclick="() => ViewDocument(doc.Id)" title="View Details">
                                    <span class="oi oi-eye"></span>
                                </button>
                                <button class="btn btn-sm btn-warning" @onclick="() => EditDocument(doc.Id)" title="Edit">
                                    <span class="oi oi-pencil"></span>
                                </button>
                                <button class="btn btn-sm btn-danger" @onclick="() => ConfirmDelete(doc.Id)" title="Delete">
                                    <span class="oi oi-trash"></span>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</AuthenticatedRoute>

@if (ShowCreateModal)
{
    <DocumentForm Document="@editingDocument" OnDocumentSaved="OnDocumentSaved" OnCancel="() => ShowCreateModal = false" />
}

@code {
    private List<Document>? documents;
    private bool ShowCreateModal = false;
    private Document editingDocument = new Document();
    private int currentUserId = 1; // Replace with actual user ID from authentication

    protected override async Task OnInitializedAsync()
    {
        await LoadDocuments();
    }

    private async Task LoadDocuments()
    {
        try
        {
            documents = (await DocumentService.GetAllDocumentsAsync()).ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading documents: {ex.Message}");
        }
    }

    private void ViewDocument(int documentId)
    {
        Navigation.NavigateTo($"/document/{documentId}");
    }

    private void EditDocument(int documentId)
    {
        var document = documents?.FirstOrDefault(d => d.Id == documentId);
        if (document != null)
        {
            editingDocument = document;
            ShowCreateModal = true;
        }
    }

    private void CreateDocument()
    {
        editingDocument = new Document { UserId = currentUserId };
        ShowCreateModal = true;
    }

    private async Task OnDocumentSaved(Document savedDocument)
    {
        ShowCreateModal = false;
        await LoadDocuments();
    }

    private async Task ConfirmDelete(int documentId)
    {
        if (await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this document?"))
        {
            await DeleteDocument(documentId);
        }
    }

    private async Task DeleteDocument(int documentId)
    {
        try
        {
            if (await DocumentService.DeleteDocumentAsync(documentId))
            {
                await LoadDocuments();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error deleting document: {ex.Message}");
        }
    }

    @inject IJSRuntime JSRuntime
}
