@page "/users"
@using global::DocumentManagement.Features.Data.Models
@using global::DocumentManagement.Features.Authentication.Models
@inject global::DocumentManagement.Features.Services.Interfaces.IUserService UserService
@inject AuthenticationStateManager AuthStateManager
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>User Management</PageTitle>

<AuthenticatedRoute>

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col">
            <h1>User Management</h1>
        </div>
        <div class="col text-end">
            <button class="btn btn-primary" @onclick="CreateUser">
                <span class="oi oi-plus"></span> Add User
            </button>
        </div>
    </div>

    <div class="row">
        <div class="col">
            <div class="card">
                <div class="card-body">
                    @if (users == null)
                    {
                        <div class="text-center">
                            <div class="spinner-border" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        </div>
                    }
                    else if (users.Count == 0)
                    {
                        <div class="text-center">
                            <p class="text-muted">No users found.</p>
                            <button class="btn btn-primary" @onclick="CreateUser">
                                <span class="oi oi-plus"></span> Add First User
                            </button>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-striped">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Full Name</th>
                                        <th>Email</th>
                                        <th>Role</th>
                                        <th>Created At</th>
                                        <th>Status</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var user in users)
                                    {
                                        var isCurrentUser = AuthStateManager.CurrentUser?.Id == user.Id;
                                        <tr class="@(isCurrentUser ? "current-user-row" : "")">
                                            <td>
                                                <div class="user-name-cell">
                                                    <span class="user-name">@user.FullName</span>
                                                    @if (isCurrentUser)
                                                    {
                                                        <span class="current-user-badge">YOU</span>
                                                    }
                                                </div>
                                            </td>
                                            <td>@user.Email</td>
                                            <td><span class="role-badge user-role">@user.Role</span></td>
                                            <td>@user.CreatedAt.ToString("g")</td>
                                            <td>
                                                <span class="user-status @(user.IsActive ? "status-active" : "status-inactive")">
                                                    <span class="status-indicator"></span>
                                                    @(user.IsActive ? "Active" : "Inactive")
                                                </span>
                                            </td>
                                            <td>
                                                <button class="btn btn-sm btn-info" @onclick="() => EditUser(user)" title="Edit">
                                                    <span class="oi oi-pencil"></span>
                                                </button>
                                                <button class="btn btn-sm btn-danger" @onclick="() => DeleteUser(user)" title="Delete">
                                                    <span class="oi oi-trash"></span>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

    @inject IJSRuntime JSRuntime
}

@code {
    private List<User>? users;

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        try
        {
            users = (await UserService.GetAllUsersAsync()).ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading users: {ex.Message}");
        }
    }

    private void CreateUser()
    {
        Navigation.NavigateTo("/users/create");
    }

    private void EditUser(User user)
    {
        Navigation.NavigateTo($"/users/edit/{user.Id}");
    }

    private async Task DeleteUser(User user)
    {
        try
        {
            await UserService.DeleteUserAsync(user.Id);
            await LoadUsers();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error deleting user: {ex.Message}");
        }
    }

    @inject IJSRuntime JSRuntime
}
