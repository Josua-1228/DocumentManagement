@page "/"
@using global::DocumentManagement.Features.Data.Models
@using global::DocumentManagement.Features.Authentication.Models
@inject global::DocumentManagement.Features.Services.Interfaces.IUserService UserService
@inject global::DocumentManagement.Features.Services.Interfaces.IDocumentService DocumentService
@inject global::DocumentManagement.Features.Services.Interfaces.IDocumentTypeService DocumentTypeService
@inject global::DocumentManagement.Features.Services.Interfaces.IUploadService UploadService
@inject AuthenticationStateManager AuthStateManager
@rendermode InteractiveServer

<PageTitle>Dashboard</PageTitle>

<AuthenticatedRoute>
    <div class="container mt-4">
        <div class="row mb-4">
            <div class="col">
                <div class="document-banner">
                    <h1>📋 Document Management Dashboard</h1>
                    <p class="document-subtitle">Welcome to your document management system</p>
                    <div class="document-stamp">CONFIDENTIAL</div>
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4 class="card-title">@userCount</h4>
                            <p class="card-text">Total Users</p>
                        </div>
                        <div class="align-self-center">
                            <span class="stats-icon">👥</span>
                        </div>
                    </div>
                </div>
                <div class="card-corner"></div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="document-card stats-card documents-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4 class="card-title">@documentCount</h4>
                            <p class="card-text">Documents</p>
                        </div>
                        <div class="align-self-center">
                            <span class="stats-icon">📄</span>
                        </div>
                    </div>
                </div>
                <div class="card-corner"></div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="document-card stats-card types-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4 class="card-title">@documentTypeCount</h4>
                            <p class="card-text">Document Types</p>
                        </div>
                        <div class="align-self-center">
                            <span class="stats-icon">🏷️</span>
                        </div>
                    </div>
                </div>
                <div class="card-corner"></div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="document-card stats-card uploads-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4 class="card-title">@uploadCount</h4>
                            <p class="card-text">File Uploads</p>
                        </div>
                        <div class="align-self-center">
                            <span class="stats-icon">📤</span>
                        </div>
                    </div>
                </div>
                <div class="card-corner"></div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="row mb-4">
        <div class="col">
            <div class="document-card actions-card">
                <div class="card-header">
                    <h5 class="card-title mb-0">⚡ Quick Actions</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-3 mb-2">
                            <a href="/users" class="document-btn action-btn users-btn w-100">
                                <span class="btn-icon">➕</span>
                                <span class="btn-text">Add User</span>
                            </a>
                        </div>
                        <div class="col-md-3 mb-2">
                            <a href="/documents" class="document-btn action-btn documents-btn w-100">
                                <span class="btn-icon">📤</span>
                                <span class="btn-text">Upload Document</span>
                            </a>
                        </div>
                        <div class="col-md-3 mb-2">
                            <a href="/document-types" class="document-btn action-btn types-btn w-100">
                                <span class="btn-icon">🏷️</span>
                                <span class="btn-text">Manage Types</span>
                            </a>
                        </div>
                        <div class="col-md-3 mb-2">
                            <a href="/uploads" class="document-btn action-btn uploads-btn w-100">
                                <span class="btn-icon">📁</span>
                                <span class="btn-text">View Uploads</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Activity -->
    <div class="row">
        <div class="col-md-6">
            <div class="document-card activity-card">
                <div class="card-header">
                    <h5 class="card-title mb-0">📄 Recent Documents</h5>
                </div>
                <div class="card-body">
                    @if (recentDocuments == null)
                    {
                        <div class="loading-spinner">
                            <div class="spinner-border spinner-border-sm" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        </div>
                    }
                    else if (recentDocuments.Count == 0)
                    {
                        <div class="empty-state">
                            <p class="text-muted">📭 No recent documents found.</p>
                        </div>
                    }
                    else
                    {
                        <div class="document-list">
                            @foreach (var doc in recentDocuments.Take(5))
                            {
                                <div class="document-item">
                                    <div class="document-info">
                                        <strong>@doc.Title</strong>
                                        <br />
                                        <small class="text-muted">👤 @doc.User?.FullName</small>
                                    </div>
                                    <div class="document-meta">
                                        <span class="document-date">📅 @doc.UploadedAt.ToString("d")</span>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="document-card activity-card">
                <div class="card-header">
                    <h5 class="card-title mb-0">👥 Recent Users</h5>
                </div>
                <div class="card-body">
                    @if (recentUsers == null)
                    {
                        <div class="loading-spinner">
                            <div class="spinner-border spinner-border-sm" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        </div>
                    }
                    else if (recentUsers.Count == 0)
                    {
                        <div class="empty-state">
                            <p class="text-muted">📭 No recent users found.</p>
                        </div>
                    }
                    else
                    {
                        <div class="document-list">
                            @foreach (var user in recentUsers.Take(5))
                            {
                                <div class="document-item">
                                    <div class="document-info">
                                        <strong>@user.FullName?.Replace("{", "").Replace("}", "")</strong>
                                        <br />
                                        <small class="text-muted">✉️ @user.Email?.Replace("{", "").Replace("}", "")</small>
                                    </div>
                                    <div class="document-meta">
                                        <span class="status-badge @(user.IsActive ? "status-active" : "status-inactive")">
                                            @(user.IsActive ? "✅ Active" : "❌ Inactive")
                                        </span>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </AuthenticatedRoute>

@code {
    private int userCount = 0;
    private int documentCount = 0;
    private int documentTypeCount = 0;
    private int uploadCount = 0;
    private List<Document>? recentDocuments;
    private List<User>? recentUsers;

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardData();
    }

    private async Task LoadDashboardData()
    {
        try
        {
            var users = await UserService.GetAllUsersAsync();
            userCount = users.Count();
            recentUsers = users.OrderByDescending(u => u.CreatedAt).ToList();

            var documents = await DocumentService.GetAllDocumentsAsync();
            documentCount = documents.Count();
            recentDocuments = documents.OrderByDescending(d => d.UploadedAt).ToList();

            var documentTypes = await DocumentTypeService.GetAllDocumentTypesAsync();
            documentTypeCount = documentTypes.Count();

            // For uploads, you might need to implement a GetAllUploadsAsync method
            // For now, we'll use a placeholder
            uploadCount = 0; // Placeholder
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading dashboard data: {ex.Message}");
        }
    }
}
